{
  "extends": "@extension/tsconfig/app",
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"]
    }
  },
  "include": ["src", "vite.config.mts", "tailwind.config.ts"],
  "exclude": ["node_modules"]
}
